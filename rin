# ──────────────────────────────────────────────

main() {
  header "BOYKISSER HAXK — Unlimited Edition"

  if [[ -n "$binary_path" ]]; then
    install_from_binary
  else
    resolve_version

    # Check if already installed and up-to-date
    if command -v rin >/dev/null 2>&1; then
      local installed_version
      installed_version=$(rin --version 2>/dev/null || echo "")
      if [[ -n "$installed_version" && -n "$specific_version" && "$specific_version" != "local" ]]; then
        version_compare "$installed_version" "$specific_version"
        case $? in
          0) muted "  Version ${specific_version} already installed — reinstalling anyway" ;;
          1) muted "  Installed: ${installed_version} > target: ${specific_version} — downgrading" ;;
          2) muted "  Upgrade available: ${installed_version} → ${specific_version}" ;;
        esac
      fi
    fi

    download_and_install
  fi

  setup_path
  setup_obedience_config

  # ──────────────────────────────────────────
  # POST-INSTALL SUMMARY
  # ──────────────────────────────────────────
  echo ""
  echo -e "  ${BOLD_RED}BOYKISSER HAXK v${specific_version}${NC} deployed to ${INSTALL_DIR}"
  echo ""
  echo -e "  ${RED}●${NC} Unlimited token limits enabled"
  echo -e "  ${RED}●${NC} Obedience mode configured (never refuses)"
  echo -e "  ${RED}●${NC} Timeouts disabled"
  echo -e "  ${RED}●${NC} Compaction disabled (full context preserved)"
  echo ""
  echo -e "  ${DIM_RED}Usage:${NC}"
  echo -e "    cd <project>  ${DIM_RED}# Navigate to your project${NC}"
  echo -e "    rin      ${DIM_RED}# Run (never refuses, no token limits)${NC}"
  echo -e "  ${DIM_RED}For docs visit ${NC}https://opencode.ai/docs"
  echo ""
}

main